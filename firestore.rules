rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Samples: only the owner can CRUD
    match /samples/{sampleId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.owner_id;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.owner_id;
    }

    // Analysis results: accessible if the caller owns the parent sample
    match /analysis_results/{resultId} {
      allow read, create: if request.auth != null
        && exists(/databases/$(database)/documents/samples/$(resource.data.sample_id))
        && get(/databases/$(database)/documents/samples/$(resource.data.sample_id)).data.owner_id == request.auth.uid;
    }
  }
}
