# Firebase web app config (from Firebase console → Project Settings → Your apps)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=omni-biosystems.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=omni-biosystems
VITE_FIREBASE_STORAGE_BUCKET=omni-biosystems.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Leave blank in dev (Vite proxy handles /api → localhost:8000)
# Set to https://omni-biosystems.com in production (Firebase Hosting rewrites /api/**)
VITE_API_BASE_URL=
